{
  "expo": {
    "name": "Contracting App",
    "slug": "contracts-portal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/contracting-app.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/contracting-app.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sitebatch.contracts",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/contracting-app.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.sitebatch.contracts"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "contractsapp",
    "extra": {
      "eas": {
        "projectId": "18147424-66e5-474a-8390-ffdfa94162af"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
